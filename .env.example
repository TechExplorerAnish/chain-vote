# ============================================================
# JUDGE/DEMO MODE - For Hackathon Evaluation
# ============================================================

# PIN-based judge access
# Share this PIN with judges - they'll enter it to access admin panel
# Example: NEXT_PUBLIC_JUDGE_MODE_PIN=solanablockchain
NEXT_PUBLIC_JUDGE_MODE_PIN=solanablockchain

# Optional: Shared judge wallet
# Judges can connect this wallet address to access admin panel
# Example: NEXT_PUBLIC_JUDGE_WALLET=HN7cABqLq46Es1jh92dQQisAq662SmxELPhJ1tKT1g3
# NEXT_PUBLIC_JUDGE_WALLET=

# ============================================================
# SOLANA CONFIGURATION
# ============================================================

# Solana RPC endpoint
# Devnet: https://api.devnet.solana.com
# Testnet: https://api.testnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Your Anchor program ID (deployed program public key)
# Example: 9JHuSg8vw8JNZ8RpyugiPejCSeY77uVs9ghRTfLe57cg
NEXT_PUBLIC_PROGRAM_ID=

# Application URL (for SEO and Open Graph)
# Example: https://chain-vote.vercel.app
NEXT_PUBLIC_APP_URL=

# Solana cluster (devnet, testnet, or mainnet-beta)
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
